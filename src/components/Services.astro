---
// Services.astro — three service cards
---
<section id="services" class="sec">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-tag" data-t="services.tag">// services</span>
      <h2 class="sec-title" data-t="services.title">What We Build</h2>
      <p class="sec-sub" data-t="services.sub">From landing pages to full builds — we handle design, dev, and deployment.</p>
    </div>

    <div class="svc-grid">
      <!-- Card 1 -->
      <div class="svc">
        <span class="svc-num" aria-hidden="true">01</span>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
        </svg>
        <h3 class="svc-name" data-t="services.s1.name">Landing Pages</h3>
        <p  class="svc-desc" data-t="services.s1.desc">High-converting single-page sites. Mobile-perfect, SEO-ready, fast delivery.</p>
        <p  class="svc-price" data-t="services.s1.price">from $50 — $150</p>
        <ul class="svc-list">
          <li class="svc-item" data-t="services.s1.f1">Fully responsive</li>
          <li class="svc-item" data-t="services.s1.f2">Contact form included</li>
          <li class="svc-item" data-t="services.s1.f3">2–3 day delivery</li>
        </ul>
      </div>

      <!-- Card 2 -->
      <div class="svc">
        <span class="svc-num" aria-hidden="true">02</span>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <h3 class="svc-name" data-t="services.s2.name">Business Websites</h3>
        <p  class="svc-desc" data-t="services.s2.desc">Multi-page websites built with Astro — blazing-fast, great SEO, easy to scale.</p>
        <p  class="svc-price" data-t="services.s2.price">from $200 — $500</p>
        <ul class="svc-list">
          <li class="svc-item" data-t="services.s2.f1">Up to 6 pages</li>
          <li class="svc-item" data-t="services.s2.f2">Astro-powered</li>
          <li class="svc-item" data-t="services.s2.f3">Free hosting on Netlify</li>
        </ul>
      </div>

      <!-- Card 3 -->
      <div class="svc">
        <span class="svc-num" aria-hidden="true">03</span>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        <h3 class="svc-name" data-t="services.s3.name">Custom Premium</h3>
        <p  class="svc-desc" data-t="services.s3.desc">Fully custom design with animations, interactions and branding from scratch.</p>
        <p  class="svc-price" data-t="services.s3.price">from $500 — $1,000+</p>
        <ul class="svc-list">
          <li class="svc-item" data-t="services.s3.f1">Custom animations</li>
          <li class="svc-item" data-t="services.s3.f2">Full brand identity</li>
          <li class="svc-item" data-t="services.s3.f3">Ongoing support</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
#services { background: var(--bg); }
.svc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(290px, 100%), 1fr));
  gap: var(--s6);
}
.svc {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r-lg); padding: var(--s8);
  position: relative; overflow: hidden;
  transition: border-color var(--ease), transform var(--ease), box-shadow var(--ease);
}
.svc::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(0,229,204,.05) 0%, transparent 55%);
  opacity: 0; transition: opacity var(--ease);
}
.svc:hover { border-color: var(--teal); transform: translateY(-2px); box-shadow: var(--teal-glow); }
.svc:hover::before { opacity: 1; }
.svc-num {
  position: absolute; top: var(--s5); right: var(--s6);
  font-family: var(--font-mono); font-size: var(--3xl); font-weight: 700;
  color: var(--text-faint); line-height: 1; pointer-events: none;
}
.svc-icon { width: 42px; height: 42px; color: var(--teal); margin-bottom: var(--s5); }
.svc-name { font-family: var(--font-mono); font-size: var(--lg); font-weight: 700; color: var(--text); margin-bottom: var(--s3); }
.svc-desc { font-size: var(--sm); color: var(--text-muted); line-height: 1.75; margin-bottom: var(--s5); }
.svc-price { font-family: var(--font-mono); font-size: var(--xs); color: var(--green); letter-spacing: .08em; }
.svc-list { margin-top: var(--s5); display: flex; flex-direction: column; gap: var(--s2); }
.svc-item {
  display: flex; align-items: center; gap: var(--s3);
  font-size: var(--xs); color: var(--text-muted);
}
.svc-item::before { content: '//'; color: var(--teal); font-family: var(--font-mono); font-size: 9px; flex-shrink: 0; }
[dir=rtl] .svc-num { right: auto; left: var(--s6); }
</style>
