---
// Nav.astro — fixed top navigation with language switcher
---
<nav>
  <div class="nav-in">
    <!-- Logo -->
    <a class="logo" href="#home">
      <svg width="28" height="28" viewBox="0 0 120 120" fill="none" aria-hidden="true">
        <rect width="120" height="120" rx="16" fill="#07110e"/>
        <path d="M20 18L10 32v56l10 14" stroke="#00e5cc" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M100 18l10 14v56l-10 14" stroke="#00e5cc" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        <text x="26" y="76" font-family="Space Mono,monospace" font-size="44" font-weight="700" fill="#00e5cc">ε</text>
        <text x="72" y="55" font-family="Space Mono,monospace" font-size="24" font-weight="700" fill="#00ff41">2</text>
      </svg>
      <span>&lt;E²&gt;</span>
    </a>

    <!-- Desktop links -->
    <div class="nav-links">
      <a href="#services"  data-t="nav.services">Services</a>
      <a href="#process"   data-t="nav.process">Process</a>
      <a href="#portfolio" data-t="nav.portfolio">Portfolio</a>
      <a href="#about"     data-t="nav.about">About</a>
      <a href="#contact"   data-t="nav.contact">Contact</a>
    </div>

    <!-- Right side: lang + hamburger -->
    <div class="nav-right">
      <div class="lang-bar">
        <button class="lang-btn" data-lang-btn="en">EN</button>
        <button class="lang-btn" data-lang-btn="de">DE</button>
        <button class="lang-btn" data-lang-btn="ar">AR</button>
      </div>
      <button class="ham" id="ham" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu -->
<div class="mob" id="mob" aria-hidden="true">
  <a href="#services"  data-t="nav.services">Services</a>
  <a href="#process"   data-t="nav.process">Process</a>
  <a href="#portfolio" data-t="nav.portfolio">Portfolio</a>
  <a href="#about"     data-t="nav.about">About</a>
  <a href="#contact"   data-t="nav.contact">Contact</a>
  <div class="mob-lang">
    <button class="lang-btn" data-lang-btn="en">EN</button>
    <button class="lang-btn" data-lang-btn="de">DE</button>
    <button class="lang-btn" data-lang-btn="ar">AR</button>
  </div>
</div>

<style>
nav {
  position: fixed; top: 0; inset-inline: 0; z-index: 200; height: 64px;
  background: rgba(3,8,6,.88); backdrop-filter: blur(20px) saturate(1.4);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
}
.nav-in {
  max-width: var(--w-wide); margin-inline: auto; padding-inline: var(--s6);
  width: 100%; display: flex; align-items: center; justify-content: space-between; gap: var(--s6);
}
.logo {
  display: flex; align-items: center; gap: var(--s3);
  font-family: var(--font-mono); font-size: var(--lg); font-weight: 700;
  color: var(--teal); text-shadow: 0 0 14px rgba(0,229,204,.55);
  flex-shrink: 0; transition: text-shadow var(--ease);
}
.logo:hover { text-shadow: var(--teal-glow); }
.nav-links { display: flex; align-items: center; gap: var(--s8); }
.nav-links a {
  font-family: var(--font-mono); font-size: var(--xs);
  color: var(--text-muted); letter-spacing: .06em;
  transition: color var(--ease);
}
.nav-links a:hover { color: var(--teal); }
.nav-right { display: flex; align-items: center; gap: var(--s3); }
.lang-bar {
  display: flex; align-items: center; gap: 2px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r-full); padding: 3px;
}
.lang-btn {
  padding: 3px 10px; border-radius: var(--r-full);
  font-family: var(--font-mono); font-size: 10px; letter-spacing: .06em;
  color: var(--text-muted); min-height: 28px;
  transition: all var(--ease);
}
.lang-btn.on { background: var(--teal); color: var(--text-inv); box-shadow: 0 0 10px rgba(0,229,204,.35); }
.lang-btn:hover:not(.on) { color: var(--teal); }
.ham {
  display: none; flex-direction: column; gap: 5px;
  padding: var(--s2); min-width: 44px; min-height: 44px;
  align-items: center; justify-content: center;
}
.ham span { display: block; width: 20px; height: 2px; background: var(--text-muted); border-radius: 2px; transition: all var(--ease); }
.ham[aria-expanded=true] span:nth-child(1) { transform: rotate(45deg) translate(5px,5px); }
.ham[aria-expanded=true] span:nth-child(2) { opacity: 0; }
.ham[aria-expanded=true] span:nth-child(3) { transform: rotate(-45deg) translate(5px,-5px); }

.mob {
  display: none; position: fixed; inset: 64px 0 0; z-index: 190;
  background: rgba(3,8,6,.97); backdrop-filter: blur(20px);
  flex-direction: column; padding: var(--s8) var(--s6); gap: 0;
  border-top: 1px solid var(--border);
}
.mob.open { display: flex; }
.mob a {
  font-family: var(--font-mono); font-size: var(--lg);
  color: var(--text-muted); padding: var(--s4) 0;
  border-bottom: 1px solid var(--border);
  transition: color var(--ease);
}
.mob a:hover { color: var(--teal); }
.mob-lang {
  display: flex; gap: var(--s3); margin-top: var(--s6);
  flex-wrap: wrap;
}
.mob-lang .lang-btn {
  padding: var(--s2) var(--s5); border: 1px solid var(--border);
  min-width: 60px; min-height: 44px;
  font-size: var(--sm); color: var(--text-muted);
  transition: all var(--ease);
}
.mob-lang .lang-btn.on { border-color: var(--teal); color: var(--teal); background: var(--teal-bg); }

@media(max-width:768px) {
  .nav-links { display: none; }
  .ham { display: flex; }
  .lang-bar { display: none; }
}
</style>

<script>
const ham  = document.getElementById('ham');
const mob  = document.getElementById('mob');
ham.addEventListener('click', () => {
  const open = mob.classList.toggle('open');
  ham.setAttribute('aria-expanded', String(open));
  mob.setAttribute('aria-hidden',   String(!open));
});
mob.querySelectorAll('a').forEach(a =>
  a.addEventListener('click', () => {
    mob.classList.remove('open');
    ham.setAttribute('aria-expanded', 'false');
  })
);
</script>
