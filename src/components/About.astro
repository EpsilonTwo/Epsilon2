---
// About.astro — terminal-style team section
---
<section id="about" class="sec">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-tag"  data-t="about.tag">// team</span>
      <h2  class="sec-title" data-t="about.title">Who We Are</h2>
    </div>
    <div class="about-grid">

      <div class="terminal">
        <div class="t-bar">
          <span class="dot" style="background:#ff5f57"></span>
          <span class="dot" style="background:#febc2e"></span>
          <span class="dot" style="background:#28c840"></span>
          <span class="t-title">epsilon2@local ~ </span>
        </div>
        <div class="t-body">
          <div class="line"><span class="prompt">$</span><span class="cmd"> cat team.json</span></div>
          <div class="line out">{</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"name"</span>: <span class="str">"Stephan"</span>,</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"role"</span>: <span class="str">"Architecture &amp; Dev"</span>,</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"tech"</span>: [<span class="str">"Astro"</span>, <span class="str">"JS"</span>, <span class="str">"CSS"</span>],</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"base"</span>: <span class="str">"Stuttgart, DE"</span></div>
          <div class="line out">},</div>
          <div class="line out">{</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"name"</span>: <span class="str">"Yara"</span>,</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"role"</span>: <span class="str">"Design &amp; Creative"</span>,</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"lang"</span>: [<span class="str">"AR"</span>, <span class="str">"EN"</span>, <span class="str">"DE"</span>],</div>
          <div class="line out">&nbsp;&nbsp;<span class="key">"base"</span>: <span class="str">"MENA Region"</span></div>
          <div class="line out">}</div>
          <div class="line"><span class="prompt">$</span><span class="cursor">_</span></div>
        </div>
      </div>

      <div class="about-copy">
        <h3 class="about-h" data-t="about.h">Two devs. One vision.</h3>
        <p data-t="about.p1">We are Stephan and Yara — a two-person web dev duo combining technical architecture with purposeful design.</p>
        <p data-t="about.p2">Based in Germany and the MENA region — we work in German, English, and Arabic.</p>
        <div class="langs">
          <span>🇩🇪 Deutsch</span>
          <span>🇬🇧 English</span>
          <span>🇸🇦 العربية</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
#about { background: var(--surface); }
.about-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: var(--s12); align-items: center;
}
.terminal {
  background: #010503; border: 1px solid var(--border);
  border-radius: var(--r-lg); overflow: hidden; font-family: var(--font-mono);
  box-shadow: 0 0 40px rgba(0,229,204,.04);
}
.t-bar {
  background: #0a1009; border-bottom: 1px solid var(--border);
  padding: var(--s3) var(--s5); display: flex; align-items: center; gap: var(--s2);
}
.dot { width: 12px; height: 12px; border-radius: 50%; }
.t-title { margin-left: var(--s3); font-size: var(--xs); color: var(--text-faint); }
.t-body { padding: var(--s5); font-size: var(--xs); line-height: 2; }
.line   { color: var(--text-muted); }
.out    { padding-left: 0; color: var(--text-muted); }
.prompt { color: var(--teal); margin-right: var(--s2); }
.cmd    { color: var(--text); }
.key    { color: var(--teal); }
.str    { color: var(--green); }
.cursor { color: var(--teal); animation: blink .9s step-end infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

.about-copy { display: flex; flex-direction: column; gap: var(--s5); }
.about-h { font-family: var(--font-mono); font-size: var(--xl); color: var(--teal); margin-bottom: var(--s2); }
.about-copy p { font-size: var(--base); color: var(--text-muted); line-height: 1.8; }
.langs { display: flex; flex-wrap: wrap; gap: var(--s3); margin-top: var(--s3); }
.langs span {
  font-family: var(--font-mono); font-size: var(--xs);
  padding: var(--s1) var(--s3); border: 1px solid var(--border);
  border-radius: var(--r-full); color: var(--text-muted);
}

@media(max-width:768px) {
  .about-grid { grid-template-columns: 1fr; }
}
[dir=rtl] .about-copy { text-align: right; }
</style>
