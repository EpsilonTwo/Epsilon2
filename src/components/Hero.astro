---
// Hero.astro — full-viewport hero with matrix rain canvas
---
<section class="hero" id="home">
  <canvas id="matrix-canvas" aria-hidden="true"></canvas>
  <div class="vignette" aria-hidden="true"></div>

  <div class="hero-inner">
    <p class="pre" data-t="hero.pre">// initializing epsilon²</p>

    <!-- Logo mark -->
    <svg class="hero-logo" width="96" height="96" viewBox="0 0 120 120" fill="none" aria-label="Epsilon2">
      <rect width="120" height="120" rx="16" fill="#07110e"/>
      <path d="M20 18L10 32v56l10 14" stroke="#00e5cc" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M100 18l10 14v56l-10 14" stroke="#00e5cc" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
      <text x="26" y="76" font-family="Space Mono,monospace" font-size="44" font-weight="700" fill="#00e5cc">ε</text>
      <text x="72" y="55" font-family="Space Mono,monospace" font-size="24" font-weight="700" fill="#00ff41">2</text>
    </svg>

    <h1 class="hero-h1" data-t="hero.title">We Build Digital Worlds.</h1>
    <p class="hero-sub" data-t="hero.sub">
      Custom websites that convert visitors into customers. Fast, beautiful, and built to last.
    </p>

    <div class="hero-btns">
      <a href="#services" class="btn-p" data-t="hero.cta1">View Services</a>
      <a href="#contact"  class="btn-g" data-t="hero.cta2">Get a Free Quote</a>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    <span data-t="hero.scroll">SCROLL</span>
  </div>
</section>

<style>
.hero {
  position: relative; min-height: 100dvh;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
#matrix-canvas { position: absolute; inset: 0; z-index: 0; opacity: .28; }
.vignette {
  position: absolute; inset: 0; z-index: 1;
  background:
    radial-gradient(ellipse 90% 70% at 50% 50%, transparent 30%, rgba(3,8,6,.75) 100%),
    linear-gradient(to bottom, rgba(3,8,6,.4) 0%, transparent 20%, transparent 80%, rgba(3,8,6,.85) 100%);
}
.hero-inner {
  position: relative; z-index: 2; text-align: center;
  padding: var(--s16) var(--s6) var(--s8); max-width: 820px;
}
.pre {
  font-family: var(--font-mono); font-size: var(--xs); color: var(--green);
  letter-spacing: .18em; text-transform: uppercase; margin-bottom: var(--s5);
  opacity: 0; animation: fadeUp .5s .05s both;
}
.hero-logo {
  margin-inline: auto; margin-bottom: var(--s6);
  opacity: 0; animation: fadeUp .5s .0s both;
}
.hero-h1 {
  font-family: var(--font-mono); font-size: var(--3xl); font-weight: 700;
  line-height: 1.08; color: var(--teal); text-shadow: var(--teal-glow);
  margin-bottom: var(--s6);
  opacity: 0; animation: fadeUp .5s .2s both;
}
.hero-sub {
  font-size: var(--base); color: var(--text-muted); line-height: 1.75;
  max-width: 52ch; margin-inline: auto; margin-bottom: var(--s10);
  opacity: 0; animation: fadeUp .5s .35s both;
}
.hero-btns {
  display: flex; gap: var(--s4); justify-content: center; flex-wrap: wrap;
  opacity: 0; animation: fadeUp .5s .5s both;
}
.scroll-hint {
  position: absolute; bottom: var(--s8); left: 50%; transform: translateX(-50%); z-index: 2;
  display: flex; flex-direction: column; align-items: center; gap: var(--s2);
  color: var(--text-faint); font-size: 10px; font-family: var(--font-mono); letter-spacing: .14em;
  animation: bob 2.4s ease-in-out infinite;
}
.scroll-line { width: 1px; height: 36px; background: linear-gradient(to bottom, var(--teal), transparent); }

@keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
@keyframes bob { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(7px)} }

@media(max-width:768px) {
  .hero-btns { flex-direction: column; align-items: center; }
}
[dir=rtl] .hero-btns { flex-direction: row-reverse; }
</style>

<script>
// Matrix rain
(function () {
  const cv = document.getElementById("matrix-canvas");
  const cx = cv.getContext("2d");
  const chars = "アイウエオカキクケコ0123456789ABCDEFε²<>/{}[]";
  let cols, drops;

  function init() {
    cv.width  = window.innerWidth;
    cv.height = window.innerHeight;
    cols  = Math.floor(cv.width / 14);
    drops = Array(cols).fill(0).map(() => Math.random() * -60);
  }

  function draw() {
    cx.fillStyle = "rgba(3,8,6,0.055)";
    cx.fillRect(0, 0, cv.width, cv.height);
    for (let i = 0; i < cols; i++) {
      const ch = chars[Math.floor(Math.random() * chars.length)];
      const b  = Math.random();
      cx.fillStyle = b > .97 ? "#fff" : b > .72 ? "#00e5cc" : b > .3 ? "#005522" : "#002211";
      cx.font = "13px 'Space Mono', monospace";
      cx.fillText(ch, i * 14, drops[i] * 14);
      if (drops[i] * 14 > cv.height && Math.random() > .978) drops[i] = 0;
      drops[i] += .5 + Math.random() * .5;
    }
  }

  init();
  window.addEventListener("resize", init);
  setInterval(draw, 55);
})();
</script>
